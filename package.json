{
  "name": "ania-avatar-react",
  "version": "1.9.2",
  "description": "React component library for ANIA Avatar with TTS, STT, and chatbot integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "piper-tts-web": "^1.1.0",
    "onnxruntime-web": ">=1.17.0"
  },
  "peerDependenciesMeta": {
    "piper-tts-web": {
      "optional": true
    },
    "onnxruntime-web": {
      "optional": true
    }
  },
  "dependencies": {
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "javascript-obfuscator": "^5.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup-plugin-obfuscator": "^1.1.0",
    "terser": "^5.46.0",
    "vite": "^5.1.4",
    "vite-plugin-dts": "^3.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rob-d3v/ania-avatar-react.git"
  },
  "keywords": [
    "react",
    "avatar",
    "tts",
    "stt",
    "chatbot",
    "ania"
  ],
  "author": "robd3v",
  "license": "MIT"
}
